# AIP Framework — environment configuration
# Copy this file to .env and fill in the relevant values.
# Only the API key for the chosen AIP_PROVIDER is required.

# --- Provider selection ---
# Options: anthropic | openai | google | ollama
AIP_PROVIDER=anthropic

# --- API keys (set the one matching AIP_PROVIDER) ---
AIP_ANTHROPIC_API_KEY=
AIP_OPENAI_API_KEY=
AIP_GOOGLE_API_KEY=
# Ollama runs locally and needs no API key — just adjust the URL if non-default
AIP_OLLAMA_BASE_URL=http://localhost:11434

# --- Optional model overrides ---
# Leave empty to use provider defaults (see src/aip/config.py PROVIDER_DEFAULTS).
# Tiering: routing = cheap+fast, reasoning = strong, critique = strongest (used by OFH).
AIP_MODEL_ROUTING=
AIP_MODEL_REASONING=
AIP_MODEL_CRITIQUE=

# --- Runtime ---
# Divergence threshold above which dissent is flagged as innovation signal (0.0-1.0)
AIP_DISSENT_THRESHOLD=0.3
# Max OFH voting rounds before escalating to human
AIP_MAX_OFH_ROUNDS=3
# Skip human approval at gates (true for batch/automated runs)
AIP_AUTO_APPROVE_GATES=false
